---
import ContactForm from '../components/ContactForm.vue';
---

<section id="contact" class="scroll-mt-20 px-6 py-24">
  <div class="mx-auto max-w-xl reveal">
    <h2 class="text-3xl font-bold text-white">联系我</h2>
    <p class="mt-4 text-gray-400">有问题或合作意向？给我留言。</p>
    <div class="mt-8">
      <ContactForm client:load />
    </div>
  </div>
</section>
