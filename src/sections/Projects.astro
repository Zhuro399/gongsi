---
---

<section id="projects" class="scroll-mt-20 px-6 py-24 bg-gray-900/50">
  <div class="mx-auto max-w-5xl">
    <h2 class="text-3xl font-bold text-white reveal">作品集</h2>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <!-- 项目卡片 1 -->
      <div class="reveal reveal-delay-1 rounded-xl border border-gray-800 bg-gray-900 p-6 transition hover:border-gray-600 hover:-translate-y-1">
        <div class="text-2xl">🚀</div>
        <h3 class="mt-4 text-lg font-semibold text-white">项目一</h3>
        <p class="mt-2 text-sm text-gray-400">
          一个实时协作工具，支持多人同时编辑，基于 WebSocket 构建。
        </p>
        <div class="mt-4 flex gap-2 text-xs text-gray-500">
          <span>React</span>
          <span>·</span>
          <span>Go</span>
          <span>·</span>
          <span>WebSocket</span>
        </div>
      </div>
      <!-- 项目卡片 2 -->
      <div class="reveal reveal-delay-2 rounded-xl border border-gray-800 bg-gray-900 p-6 transition hover:border-gray-600 hover:-translate-y-1">
        <div class="text-2xl">📊</div>
        <h3 class="mt-4 text-lg font-semibold text-white">项目二</h3>
        <p class="mt-2 text-sm text-gray-400">
          数据分析平台，可视化展示业务指标，支持自定义查询。
        </p>
        <div class="mt-4 flex gap-2 text-xs text-gray-500">
          <span>Vue</span>
          <span>·</span>
          <span>Python</span>
          <span>·</span>
          <span>PostgreSQL</span>
        </div>
      </div>
      <!-- 项目卡片 3 -->
      <div class="reveal reveal-delay-3 rounded-xl border border-gray-800 bg-gray-900 p-6 transition hover:border-gray-600 hover:-translate-y-1">
        <div class="text-2xl">📝</div>
        <h3 class="mt-4 text-lg font-semibold text-white">项目三</h3>
        <p class="mt-2 text-sm text-gray-400">
          轻量级 Markdown 笔记应用，支持全文搜索和标签管理。
        </p>
        <div class="mt-4 flex gap-2 text-xs text-gray-500">
          <span>Astro</span>
          <span>·</span>
          <span>Supabase</span>
        </div>
      </div>
    </div>
  </div>
</section>
